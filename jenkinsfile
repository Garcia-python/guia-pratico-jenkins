pipeline{
    agent any

    stages{
        stage('build docker Image'){
            steps{
                sh 'echo "Executando o comando Docker Build"'
            }
        }
        stage('Push Docker Image'){
            steps{
                sh 'echo "Executando o comando Docker Push"'
            }
        }
        stage('Deploy no Kubernetes'){
            steps{
                sh 'echo "Executando o comando kubectl Apply"'
            }
        }
    }
}